{
  "entities": {
    "User": {
      "title": "User",
      "description": "User profile information stored in Firestore (optional metadata)",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string" },
        "role": { "type": "string", "enum": ["admin", "staff", "student"] },
        "name": { "type": "string" },
        "department": { "type": "string" },
        "course": { "type": "string" },
        "year": { "type": "string" }
      },
      "required": ["uid", "email", "role"]
    }
  },
  "firestore": {
    "/users/{uid}": {
      "schema": "User",
      "description": "User profiles"
    }
  }
}
